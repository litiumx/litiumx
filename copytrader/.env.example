# Telegram API credentials (from my.telegram.org)
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here
TG_PHONE=+7XXXXXXXXXX
TG_SESSION_NAME=copytrader_session

# Source channel to listen
TG_SOURCE_CHANNEL=-1002426663579
TG_SOURCE_CHANNEL_NAME="Торговля, спекуляции"

# Bot for notifications (created via @BotFather)
TG_BOT_TOKEN=your_bot_token_here
TG_ALERT_CHAT_ID=your_chat_id_here

# BingX API credentials
BINGX_API_KEY=your_api_key_here
BINGX_API_SECRET=your_api_secret_here
BINGX_DEMO=true

# Trading parameters
RISK_PER_TRADE_PCT=5.0
MAX_LEVERAGE=20
MAX_OPEN_POSITIONS=3
POSITION_TIMEOUT_H=48
ENTRY_DELAY_SEC=30
TP_SIZES=40,30,30
SLIPPAGE_BPS_MAX=30
MAX_DAILY_LOSS_PCT=15.0
CIRCUIT_BREAKER_LOSSES=3
CIRCUIT_BREAKER_PAUSE_MIN=60

# Risk caps for major coins correlation
MAX_MAJOR_POSITIONS=2

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/copytrader

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/copytrader/copytrader.log

# Health check
HEALTH_PORT=8200

# Kill switch (set to true to stop all trading immediately)
KILL_SWITCH=false
