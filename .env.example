# Шаблон файла .env для криптобота
# Скопируйте этот файл в .env и заполните своими данными

# API ключи биржи (например, Binance)
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Режим песочницы (true/false) - для тестирования без реальных денег
SANDBOX=false

# ID биржи: binance, bybit, okx, kraken, etc.
EXCHANGE_ID=binance

# Настройки торговли
DEFAULT_SYMBOL=BTC/USDT
DEFAULT_AMOUNT=0.001
DEFAULT_TIMEFRAME=1h
